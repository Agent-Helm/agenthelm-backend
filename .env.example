# --- Server ---
PORT=4000
# Comma-separated allowed CORS origins (the frontend dev URL).
CORS_ORIGINS=http://localhost:3000

# --- Chain ---
CHAIN_ID=8453                         # 8453 Base mainnet
RPC_URL=                              # Base RPC for quotes / eth_call simulations
ENS_RPC_URL=                          # optional Ethereum mainnet RPC for ENS resolution
DUST_EXECUTOR_ADDRESS=                # deployed DustExecutor for approvals/execution

# --- Third-party API keys (server-side only; browser never sees these) ---
ALCHEMY_API_KEY=                      # Base balances, token metadata, prices
GOPLUS_APP_KEY=                       # optional; authenticated GoPlus tier
COINGECKO_API_KEY=                    # optional; market-price fallback
COINMARKETCAP_API_KEY=                # optional; market-price fallback
# DeFiLlama prices need no key.
